# GitHub Actions Secrets for Local Testing
# Copy this file to .secrets and fill in your values
# WARNING: Never commit .secrets to version control!

# Required for org-connected tests
SFDX_HUB_KEY_BASE64=
SFDX_CLIENT_ID=
SFDX_HUB_USERNAME=

# Optional: GitHub token for API calls
GITHUB_TOKEN=

# Optional: CumulusCI keychain key
CUMULUSCI_KEY=

# Optional: For integration tests
CUMULUSCI_SERVICE_github=
CCITEST_APP_KEY=
